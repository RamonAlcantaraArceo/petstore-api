# Environment variable reference — copy to .env and fill in values.
# Never commit a .env file with real secrets.

# Runtime mode: memory | local | cloud
STORAGE_MODE=memory

# Required API key for authentication
# API_KEY=your-secret-api-key-here

# Application environment: dev | staging | prod
APP_ENV=dev

# Enable debug mode (true | false)
DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# PostgreSQL connection URL (required when STORAGE_MODE=local or cloud)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
